# 与 app/config/settings.py 对应（pydantic-settings 会读取同名环境变量）
APP_NAME="anti-fraud-agent-backend"
ENV="dev"

# SQLite by default. You can change to e.g. sqlite:///./data/app.db
DATABASE_URL="sqlite:///./data/app.db"

# JWT (Change in production)
JWT_SECRET_KEY="change_me_to_a_long_random_secret"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Upload storage
STORAGE_DIR="./storage"
MAX_UPLOAD_MB=50

# 火山方舟：向量化（Bearer，与文档一致 POST /api/v3/embeddings）
DOUBAO_ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
DOUBAO_API_KEY=""
DOUBAO_EMBEDDING_MODEL="doubao-embedding-vision-251215"

# Milvus
MILVUS_URI="http://127.0.0.1:19530"
MILVUS_TOKEN=""
MILVUS_COLLECTION="anti_fraud_text_kb"
MILVUS_EMBEDDING_DIM=2048

KB_CHUNK_MAX_CHARS=500
KB_CHUNK_OVERLAP_CHARS=80
