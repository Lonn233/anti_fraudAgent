APP_NAME="anti-fraud-agent-backend"
ENV="dev"

# SQLite by default. You can change to e.g. sqlite:///./data/app.db
DATABASE_URL="sqlite:///./data/app.db"

# Change in production
JWT_SECRET_KEY="e9078df646e5894de070695468b916293a192ade9a527eb97b9f379f4509d924"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Upload storage
STORAGE_DIR="./storage"
MAX_UPLOAD_MB=50
PUBLIC_BASE_URL="http://127.0.0.1:8010"

# 火山方舟：向量化（Bearer，POST {DOUBAO_ARK_BASE_URL}/embeddings）
DOUBAO_ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
DOUBAO_API_KEY="0d303574-21c9-4946-88d2-142d0253a539"
DOUBAO_EMBEDDING_MODEL="doubao-embedding-text-240715"
DOUBAO_CHAT_MODEL="doubao-seed-1-8-251228"

# ---------- embedding ----------
EMBEDDING_BACKEND="sentence_transformers"  # sentence_transformers（本地）/ doubao（豆包API）
SENTENCE_TRANSFORMER_MODEL="BAAI/bge-small-zh-v1.5"

# Milvus（向量库）
MILVUS_URI="http://127.0.0.1:19530"
MILVUS_TOKEN=""
MILVUS_COLLECTION="anti_fraud_contents"
MILVUS_EMBEDDING_DIM=512

# 知识库文本分段（/kb/text/upload）
KB_CHUNK_MAX_CHARS=500
KB_CHUNK_OVERLAP_CHARS=80

# ---------- model_detect ----------
MODEL_DETECT_DEVICE="cuda"

# 先用你当前实现里的零样本分类（无需先训练）
MODEL_DETECT_FRAUD_LABELS="刷单诈骗,虚假征信诈骗,贷款诈骗,投资理财诈骗,冒充客服诈骗"
MODEL_DETECT_TEXT_CLS_MODEL="MoritzLaurer/mDeBERTa-v3-base-mnli-xnli"

# AI语音二分类模型（先留空，接口会提示未配置，不会崩）
MODEL_DETECT_AI_VOICE_MODEL=""

# ASR：3060 上建议先 medium，稳定后再试 large-v3
MODEL_DETECT_ASR_MODEL="medium"

# OCR 中文
MODEL_DETECT_OCR_LANG="ch"

# 视频抽帧数（MVP 先 3 帧）
MODEL_DETECT_MAX_VIDEO_FRAMES=3

#ASR微服务
ASR_SERVICE_BASE_URL="http://127.0.0.1:8020"
ASR_SERVICE_TIMEOUT_SEC=180